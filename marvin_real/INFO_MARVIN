PASOS PARA CORRER MARVIN FÍSICO
================================

INICIO RÁPIDO (2 TERMINALES - RECOMENDADO)
==========================================

1. TERMINAL 1 - EN EL ROBOT (DOCKER)
------------------------------------
ssh marvin@192.168.31.129

# Primera vez o cuando necesites sincronizar
sudo date -s "2026-04-13 16:01:00"

# Entrar en docker (sin mando)
sudo docker run -it --net=host --device=/dev/input/event0 --device=/dev/input/event1 --device=/dev/myserial --device=/dev/rplidar --env="DISPLAY" --env="QT_X11_NO_MITSHM=1" -v /tmp/.X11-unix:/tmp/.X11-unix marvin:latest /bin/bash

# O con mando (agregar event2 y js0)
sudo docker run -it --net=host --device=/dev/input/event0 --device=/dev/input/event1 --device=/dev/input/event2 --device=/dev/input/js0 --device=/dev/myserial --device=/dev/rplidar --env="DISPLAY" --env="QT_X11_NO_MITSHM=1" -v /tmp/.X11-unix:/tmp/.X11-unix marvin:latest /bin/bash

# Dentro del contenedor
colcon build
source install/setup.bash
export ROS_DOMAIN_ID=1

# LANZAR TODOS LOS NODOS EN UNA SOLA TERMINAL
ros2 launch marvincar_bringup full_system_launch.py

# LISTO! Verás los logs de:
# - Driver Ackman (bringup)
# - LIDAR LD19
# - SLAM Mapping


2. TERMINAL 2 - EN LA LAPTOP
-----------------------------
cd MARVIN
source install/setup.bash
export ROS_DOMAIN_ID=1

# Ver el mapa en RViz
ros2 launch marvincar_nav full_viz_control_launch.py

# EN OTRA TERMINAL (TERMINAL 3 OPCIONAL - para control)
cd MARVIN
source install/setup.bash
export ROS_DOMAIN_ID=1
ros2 run teleop_twist_keyboard teleop_twist_keyboard


